# Bambu printer LAN MQTT settings
BAMBULAB_TRANSPORT=local_mqtt
BAMBULAB_HOST=192.168.1.50
BAMBULAB_PORT=8883
BAMBULAB_SERIAL=01P00A000000000
BAMBULAB_ACCESS_CODE=12345678
BAMBULAB_USERNAME=bblp
BAMBULAB_REQUEST_PUSHALL=true

# Exporter behavior
POLLING_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=8
RECONNECT_INTERVAL_SECONDS=5

# HTTP server
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9109

# Labels and logging
PRINTER_NAME=bambu-x1c
SITE=home
LOCATION=lab
LOG_LEVEL=INFO
