# Bambu printer LAN MQTT settings
BAMBULAB_TRANSPORT=local_mqtt
BAMBULAB_HOST=192.168.1.50
BAMBULAB_PORT=8883
BAMBULAB_SERIAL=01P00A000000000
BAMBULAB_ACCESS_CODE=12345678
BAMBULAB_USERNAME=bblp
BAMBULAB_REQUEST_PUSHALL=true

# Cloud MQTT settings (set BAMBULAB_TRANSPORT=cloud_mqtt)
# BAMBULAB_CLOUD_MQTT_HOST=us.mqtt.bambulab.com
# BAMBULAB_CLOUD_MQTT_PORT=8883
# BAMBULAB_CLOUD_USER_ID=1234567
# BAMBULAB_CLOUD_ACCESS_TOKEN=eyJ...
# BAMBULAB_CLOUD_REFRESH_TOKEN=
BAMBULAB_CLOUD_EMAIL=you@example.com
# Optional one-time code for auto re-auth on startup if token is missing/expired
# BAMBULAB_CLOUD_CODE=123456

# Shared config directory (host-mounted volume)
BAMBULAB_CONFIG_DIR=/config/bambulab-metrics-exporter
BAMBULAB_CREDENTIALS_FILE=credentials.enc.json
# IMPORTANT: keep this in docker secret or external env, not in git
# BAMBULAB_SECRET_KEY=replace-with-strong-random-secret

# Exporter behavior
POLLING_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=8
RECONNECT_INTERVAL_SECONDS=5

# HTTP server
LISTEN_HOST=0.0.0.0
LISTEN_PORT=9109

# Labels and logging
PRINTER_NAME=bambu-x1c
SITE=home
LOCATION=lab
LOG_LEVEL=INFO
